import { NextRequest, NextResponse } from "next/server";
import { askClaude, hasKey } from "@/lib/ai";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";

const SYSTEM = `You are FanZone 26, a friendly in-stadium concierge for fans at the FIFA World Cup 2026.
You help with wayfinding, avoiding crowds, food & stalls, seat info, accessibility, medical/volunteer/security help, and general match questions.
Be concise, warm, and practical. Use short paragraphs or tight bullet lists. If a fan describes an emergency (injury, missing person, threat), tell them exactly which in-app SOS button to tap (Medical, Volunteer, or Security) and to stay where they are.`;

function fallback(message: string): string {
  const m = message.toLowerCase();
  if (m.includes("bathroom") || m.includes("restroom") || m.includes("toilet"))
    return "The nearest restrooms are on the North-East concourse (near Gate A) and South-West concourse (near Gate E). Open the Navigation tab and tap the restroom icon to route you from your seat.";
  if (m.includes("hungry") || m.includes("food") || m.includes("eat") || m.includes("stall"))
    return "Shortest food lines right now: Hydration Station (2 min) and Green Card Vegan (3 min). Prefer a burger? Golden Boot Grill is ~8 min. Open the Food tab to order to your seat.";
  if (m.includes("crowd") || m.includes("busy") || m.includes("exit"))
    return "To leave with less crush, head to the South Upper concourse — it's the least congested right now. Check the Crowd tab for a live heatmap and the calmest gate.";
  if (m.includes("medical") || m.includes("hurt") || m.includes("injured"))
    return "If someone is injured, tap the red Medical SOS on the Help tab — it shares your seat with the nearest medical bay. Stay put; a responder will come to you.";
  if (m.includes("lost") || m.includes("missing"))
    return "For a missing person, tap Security SOS on the Help tab and describe them. Stadium security and the control room are alerted instantly with your location.";
  return "I'm your FanZone 26 concierge! I can help you find your seat, dodge crowds, order food, get medical/volunteer/security help, or talk match stats. Try asking 'where's the nearest exit?' or 'shortest food line?' (Add an ANTHROPIC_API_KEY in Vercel to unlock full AI answers.)";
}

export async function POST(req: NextRequest) {
  try {
    const { message } = await req.json();
    const text = (message || "").toString().slice(0, 2000);
    const ai = await askClaude(SYSTEM, text, 600);
    return NextResponse.json({
      reply: ai || fallback(text),
      live: !!ai,
      keyConfigured: hasKey(),
    });
  } catch {
    return NextResponse.json(
      { reply: "Something went wrong — please try again.", live: false, keyConfigured: hasKey() },
      { status: 200 }
    );
  }
}
